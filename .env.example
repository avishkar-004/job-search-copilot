# Copy this file to `.env` and fill in your credentials.
# The bot reads these from your shell environment — never committed to git.

# --- AI provider (Groq is the free default — get a key at https://console.groq.com) ---
GROQ_API_KEY=

# Optional: Gemini if you flip provider in profile.yaml
# GEMINI_API_KEY=

# --- Platform logins (only needed for platforms you'll use) ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

NAUKRI_EMAIL=
NAUKRI_PASSWORD=

INDEED_EMAIL=
INDEED_PASSWORD=

INTERNSHALA_EMAIL=
INTERNSHALA_PASSWORD=

UNSTOP_EMAIL=
UNSTOP_PASSWORD=

WELLFOUND_EMAIL=
WELLFOUND_PASSWORD=

GLASSDOOR_EMAIL=
GLASSDOOR_PASSWORD=

# Cutshort and YCombinator are public — no creds needed.

# --- Dashboard (optional) ---
DASHBOARD_SECRET=change-me-to-something-random
